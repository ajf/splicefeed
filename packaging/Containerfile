# Container image for splicefeed (glibc dynamic build).
#
# Prebuilt multi-arch images are published by CI:
#   podman pull ghcr.io/ajf/splicefeed:latest
# To build it yourself:
#   podman build -t ghcr.io/ajf/splicefeed -f packaging/Containerfile .
#
# Runtime expects a config at /etc/splicefeed/config.toml with
# data_dir = "/data"; mount both (see splicefeed.container).

FROM docker.io/library/rust:1-bookworm AS build
WORKDIR /src
COPY . .
RUN cargo build --workspace --release

# distroless/cc — glibc + libgcc + CA certificates, no shell or package
# manager: ~4x smaller than debian-slim and a far smaller attack surface.
# glibc 2.36 matches the bookworm build stage; the bundled CA certs cover
# reqwest/rustls TLS (no apt install needed). The `:nonroot` tag runs as
# uid 65532. musl/alpine would require the static build we dropped, and
# there is no shell — debug with `podman logs`, not `exec`.
FROM gcr.io/distroless/cc-debian12:nonroot
COPY --from=build /src/target/release/splicefeed /usr/local/bin/splicefeed
# Ship license notices with the binary (Apache-2.0 §4 attribution).
COPY LICENSE THIRD-PARTY-LICENSES.md /usr/share/doc/splicefeed/
ENV SPLICEFEED_CONFIG=/etc/splicefeed/config.toml
EXPOSE 8380
VOLUME /data
ENTRYPOINT ["/usr/local/bin/splicefeed"]
CMD ["run"]
